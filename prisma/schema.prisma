generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id          String           @id @default(cuid())
  nome        String
  email       String           @unique
  senha       String
  cpf         String           @unique
  telefone    String
  criadoEm   DateTime         @default(now())
  empresas    EmpresaUsuario[]
  lotes       Lote[]
  lancamentos Lancamento[]
}

model Empresa {
  id             String           @id @default(cuid())
  nome           String
  razaoSocial    String
  cnpj           String           @unique
  endereco       String
  cidade         String
  estado         String
  codigoConvite  String           @unique @default(cuid())
  criadoEm      DateTime         @default(now())
  usuarios       EmpresaUsuario[]
  contas         Conta[]
  lotes          Lote[]
  lancamentos    Lancamento[]
}

model EmpresaUsuario {
  id         String   @id @default(cuid())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  empresaId  String
  papel      Papel    @default(COLABORADOR)
  criadoEm  DateTime @default(now())

  @@unique([usuarioId, empresaId])
}

model Conta {
  id          String       @id @default(cuid())
  codigo      String
  nome        String
  tipo        TipoConta
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  empresaId   String
  contaPai    Conta?       @relation("ContaFilhas", fields: [contaPaiId], references: [id])
  contaPaiId  String?
  filhas      Conta[]      @relation("ContaFilhas")
  lancamentos Lancamento[]
}

model Lote {
  id          String       @id @default(cuid())
  historico   String
  data        DateTime
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  empresaId   String
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  usuarioId   String
  lancamentos Lancamento[]
  criadoEm   DateTime     @default(now())
}

model Lancamento {
  id        String         @id @default(cuid())
  valor     Decimal
  tipo      TipoLancamento
  conta     Conta          @relation(fields: [contaId], references: [id])
  contaId   String
  lote      Lote           @relation(fields: [loteId], references: [id])
  loteId    String
  empresa   Empresa        @relation(fields: [empresaId], references: [id])
  empresaId String
  usuario   Usuario        @relation(fields: [usuarioId], references: [id])
  usuarioId String
  criadoEm DateTime       @default(now())
}

enum TipoConta {
  ATIVO
  PASSIVO
  PATRIMONIO_LIQUIDO
  RECEITA
  DESPESA
}

enum TipoLancamento {
  DEBITO
  CREDITO
}

enum Papel {
  ADMIN
  COLABORADOR
}